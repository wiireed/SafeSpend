# Chain
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=
USER_ADDRESS=
AUTHORIZED_AGENT_ADDRESS=

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Deployed addresses (filled by Deploy.s.sol output -> shared/addresses.ts)
VAULT_ADDRESS=
USDC_ADDRESS=

# Mainnet ENS (read-only). Defaults to https://eth.llamarpc.com if unset.
# Override with an Alchemy/Infura/Ankr key if you hit rate limits.
# MAINNET_RPC_URL is read by the server-side agent (agent/src/ens.ts).
# NEXT_PUBLIC_MAINNET_RPC_URL is read by the browser (web/lib/ens.ts).
MAINNET_RPC_URL=
NEXT_PUBLIC_MAINNET_RPC_URL=
