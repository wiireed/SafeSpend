{
  "name": "safespend",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts -vvv",
    "abis:export": "forge build --root contracts && bash scripts/export-abis.sh",
    "anvil": "anvil",
    "fuji:deploy": "bash scripts/deploy-fuji.sh",
    "fuji:seed": "bash scripts/seed-fuji.sh"
  }
}
